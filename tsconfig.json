{
	"compilerOptions": {
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "Node16",
		"target": "es2020",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "node16",
		"importHelpers": true,
		"isolatedModules": true,
		"strictNullChecks": true,
		"allowSyntheticDefaultImports": true,
		"lib": ["DOM", "ES2020"]
	},
	"include": ["**/*.ts"]
}
